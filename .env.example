# Copy this file to .env and fill in your values before running docker compose.
#
# The SA_PASSWORD must satisfy SQL Server complexity rules:
#   - At least 8 characters
#   - Mix of uppercase, lowercase, digits, and special characters
#
SA_PASSWORD=YourStrongP@ssword1

# Must be at least 32 characters (used to sign JWT tokens)
JWT_KEY=YourSuperSecretJwtKeyMustBe32Chars+
